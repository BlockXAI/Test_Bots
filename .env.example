TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Comma-separated UTC hours to run tests (24h format)
# Default: 06:00 and 18:00 UTC
SCHEDULE_HOURS=6,18

# Timezone for display in reports
TIMEZONE=Asia/Kolkata

# Optional: only send Telegram messages on failure
NOTIFY_ON_SUCCESS=true
