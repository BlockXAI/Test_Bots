TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Comma-separated UTC hours to run tests (24h format)
# Default: 06:00 and 18:00 UTC
SCHEDULE_HOURS=6,18

# Timezone for display in reports
TIMEZONE=Asia/Kolkata

# Optional: only send Telegram messages on failure
NOTIFY_ON_SUCCESS=true

# Web dashboard port (Railway sets PORT automatically)
# WEB_PORT=8080

# Public URL for report links in Telegram messages
# On Railway this will be like https://chinku-production.up.railway.app
# BASE_URL=https://your-app.up.railway.app

# PostgreSQL connection string for durable report storage
# DATABASE_URL=postgresql://user:password@host:port/dbname
